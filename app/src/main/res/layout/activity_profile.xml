<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6">

    <!-- Header Gradient Ungu-Biru -->
    <RelativeLayout
        android:id="@+id/profile_header"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="@drawable/bg_top_gradient"
        android:paddingTop="36dp"
        android:paddingHorizontal="20dp">

        <ImageView
            android:id="@+id/btn_back_profile"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:src="?android:attr/homeAsUpIndicator"
            app:tint="#333333" />

        <!-- Wadah Lingkaran Foto Profil -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_foto_container"
            android:layout_width="74dp"
            android:layout_height="74dp"
            android:layout_toRightOf="@id/btn_back_profile"
            android:layout_centerVertical="true"
            android:layout_marginStart="16dp"
            app:cardCornerRadius="37dp"
            app:cardElevation="4dp">

            <ImageView
                android:id="@+id/img_foto_profil"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_user" />
        </androidx.cardview.widget.CardView>

        <!-- Informasi Nama Akun -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toRightOf="@id/card_foto_container"
            android:layout_centerVertical="true"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txt_nama_profil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hi, User"
                android:textColor="#333333"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Selamat datang kembali"
                android:textColor="#555555"
                android:textSize="13sp" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Konten Informasi Profil Hasil Edit yang Sangat Rapi -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/profile_header"
        android:layout_above="@id/profile_bottom_nav"
        android:layout_marginTop="-24dp"
        android:background="@drawable/bg_form"
        android:elevation="8dp"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- KATEGORI: DATA INFORMASI SAYA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Informasi Akun"
                android:textColor="#222222"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <!-- Baris Tampilan Email -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Alamat Email"
                    android:textColor="#888888"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/txt_email_profil"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="belum diisi"
                    android:textColor="#333333"
                    android:textSize="14sp" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E7EB"/>

            <!-- Baris Tampilan Nomor HP -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nomor Handphone"
                    android:textColor="#888888"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/txt_nohp_profil"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="belum diisi"
                    android:textColor="#333333"
                    android:textSize="14sp" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E7EB"/>

            <!-- Baris Tampilan Bio Singkat -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bio Singkat"
                    android:textColor="#888888"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/txt_bio_profil"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="belum diisi"
                    android:textColor="#333333"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- KATEGORI: AKSI -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pengaturan"
                android:textColor="#222222"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"/>

            <!-- Tombol untuk Membuka Halaman Edit -->
            <LinearLayout
                android:id="@+id/row_profil_saya"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:paddingVertical="14dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚙️   Ubah/Edit Profil Saya"
                    android:textColor="#00BCD4"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Tombol Logout -->
            <Button
                android:id="@+id/btn_logout"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="24dp"
                android:backgroundTint="#FF5252"
                android:text="Logout"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navbar -->
    <include
        android:id="@+id/profile_bottom_nav"
        layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true" />

</RelativeLayout>