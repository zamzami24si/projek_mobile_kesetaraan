<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6">

    <!-- Header Atas: Tetap Menggunakan Background Gradient -->
    <LinearLayout
        android:id="@+id/chat_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="@drawable/bg_top_gradient"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="36dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <!-- Tombol Kembali -->
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="?android:attr/homeAsUpIndicator"
            app:tint="#333333" />

        <!-- Wadah Avatar Bulat & Indikator Online -->
        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp">

            <!-- Avatar Inisial Huruf -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvAvatarContainer"
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp">

                <TextView
                    android:id="@+id/tvAvatarDetailChat"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#E5E7EB"
                    android:gravity="center"
                    android:text="P"
                    android:textColor="#4E69FF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </androidx.cardview.widget.CardView>

            <!-- Indikator Status Online Bulat Hijau -->
            <androidx.cardview.widget.CardView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_alignBottom="@id/cvAvatarContainer"
                android:layout_alignEnd="@id/cvAvatarContainer"
                android:layout_marginEnd="-2dp"
                android:layout_marginBottom="-2dp"
                app:cardBackgroundColor="#4CAF50"
                app:cardCornerRadius="6dp"
                app:cardElevation="2dp">
            </androidx.cardview.widget.CardView>
        </RelativeLayout>

        <!-- Informasi Nama & Status -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNamaDetailChat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nama Pengguna"
                android:textColor="#333333"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvStatusDetailChat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Online"
                android:textColor="#4CAF50"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bar Tempat Mengetik Pesan: DIKUNCI MATI di paling bawah layar dengan margin aman -->
    <LinearLayout
        android:id="@+id/chat_input_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:elevation="24dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="36dp"> <!-- Didongkrak naik tinggi dengan paddingBottom 36dp -->

        <!-- Kolom Input Teks -->
        <EditText
            android:id="@+id/etPesan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_form"
            android:hint="Tulis balasan..."
            android:inputType="textCapSentences|textMultiLine"
            android:maxLines="4"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:textColor="#333333"
            android:textColorHint="#999999"
            android:textSize="14sp" />

        <!-- Tombol Kirim Pesan Bulat Biru -->
        <androidx.cardview.widget.CardView
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginStart="12dp"
            app:cardBackgroundColor="#4E69FF"
            app:cardCornerRadius="23dp"
            app:cardElevation="4dp">

            <ImageView
                android:id="@+id/btnKirim"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="center"
                android:src="@android:drawable/ic_menu_send"
                app:tint="#FFFFFF" />
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- Area Daftar Pesan: Otomatis mengisi ruang kosong di antara header dan tempat mengetik -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPesan"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/chat_header"
        android:layout_above="@id/chat_input_bar"
        android:clipToPadding="false"
        android:padding="16dp" />

</RelativeLayout>